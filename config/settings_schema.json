[
  {
    "name": "theme_info",
    "theme_name": "KI Boost Studio",
    "theme_author": "KI Boost Studio",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/nicofrommer-web/ki-boost-studio-shopify",
    "theme_support_url": "https://github.com/nicofrommer-web/ki-boost-studio-shopify/issues"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 300,
        "step": 5,
        "unit": "px",
        "label": "Logo-Breite",
        "default": 150
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Wird auf 32 x 32px skaliert"
      }
    ]
  },
  {
    "name": "Farben",
    "settings": [
      {
        "type": "header",
        "content": "Markenfarben: Schwarz, Weiß, Gold"
      },
      {
        "type": "color",
        "id": "color_black",
        "label": "Schwarz",
        "default": "#0B0B0C"
      },
      {
        "type": "color",
        "id": "color_ink",
        "label": "Textfarbe (dunkel)",
        "default": "#181818"
      },
      {
        "type": "color",
        "id": "color_white",
        "label": "Weiß",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_offwhite",
        "label": "Off-White (Hintergrund)",
        "default": "#F6F4EF"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Gold (Akzent)",
        "default": "#C6A15B"
      },
      {
        "type": "color",
        "id": "color_gold_light",
        "label": "Gold hell",
        "default": "#E8D6AE"
      }
    ]
  },
  {
    "name": "Typografie",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Schrift Überschriften",
        "default": "playfair_display_n7"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Schrift Fließtext",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Maximale Seitenbreite",
        "default": 1280
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram-URL"
      },
      {
        "type": "text",
        "id": "social_linkedin",
        "label": "LinkedIn-URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook-URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube-URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok-URL"
      }
    ]
  },
  {
    "name": "Kontakt",
    "settings": [
      {
        "type": "text",
        "id": "contact_email",
        "label": "Kontakt-E-Mail",
        "default": "hallo@ki-boost-studio.de"
      },
      {
        "type": "text",
        "id": "contact_phone",
        "label": "Telefonnummer"
      },
      {
        "type": "text",
        "id": "contact_address",
        "label": "Adresse"
      }
    ]
  }
]
