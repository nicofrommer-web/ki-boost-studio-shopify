<section class="section-padding {{ section.settings.background }}">
  <div class="container">
    <div class="section-heading {% if section.settings.center_heading %}text-center{% endif %}">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="heading-xl">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="section-heading__lede">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="benefits-grid">
      {% for block in section.blocks %}
        {% if block.type == 'benefit' %}
          <div class="benefit-item" {{ block.shopify_attributes }}>
            <div class="benefit-item__icon">{% render 'icon-render', icon: block.settings.icon %}</div>
            <div>
              <h3 class="benefit-item__title">{{ block.settings.title }}</h3>
              <p class="benefit-item__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vorteile",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "bg-white", "label": "Weiß" },
        { "value": "bg-offwhite", "label": "Off-White" }
      ],
      "default": "bg-offwhite"
    },
    { "type": "checkbox", "id": "center_heading", "label": "Überschrift zentrieren", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Kicker-Text", "default": "Warum KI Boost Studio" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Deine Vorteile auf einen Blick" },
    { "type": "textarea", "id": "subheading", "label": "Untertitel", "default": "" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Vorteil",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "clock", "label": "Zeit" },
            { "value": "chart", "label": "Wachstum" },
            { "value": "shield", "label": "Sicherheit" },
            { "value": "heart", "label": "Betreuung" },
            { "value": "automation", "label": "Automation" },
            { "value": "check", "label": "Qualität" }
          ],
          "default": "clock"
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "Zeitersparnis" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Automatisierte Prozesse sparen dir und deinem Team jede Woche wertvolle Arbeitszeit." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vorteile",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "clock", "title": "Zeitersparnis", "text": "Automatisierte Prozesse sparen dir und deinem Team jede Woche wertvolle Arbeitszeit." } },
        { "type": "benefit", "settings": { "icon": "chart", "title": "Messbares Wachstum", "text": "Mehr Leads, mehr Reichweite und mehr Umsatz – transparent nachvollziehbar." } },
        { "type": "benefit", "settings": { "icon": "shield", "title": "DSGVO-konform", "text": "Alle Lösungen erfüllen deutsche und europäische Datenschutzstandards." } },
        { "type": "benefit", "settings": { "icon": "heart", "title": "Persönliche Betreuung", "text": "Ein festes Team begleitet dich – keine anonymen Ticket-Systeme." } },
        { "type": "benefit", "settings": { "icon": "automation", "title": "State-of-the-Art KI", "text": "Wir setzen auf aktuelle, leistungsstarke KI-Technologien statt Standardlösungen." } },
        { "type": "benefit", "settings": { "icon": "check", "title": "Volle Transparenz", "text": "Klare Pakete, klare Kosten, klare Ergebnisse – keine versteckten Kosten." } }
      ]
    }
  ]
}
{% endschema %}
