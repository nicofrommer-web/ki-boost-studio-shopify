<article class="section-padding">
  <div class="container">
    <div class="rich-text">
      <p class="breadcrumb" style="justify-content:flex-start; color: var(--color-black); opacity:0.5;">
        <a href="{{ blog.url }}">&larr; {{ 'blogs.article.back_to_blog' | t }}</a>
      </p>
      <h1 class="heading-xl">{{ article.title }}</h1>
      <p style="opacity:0.6;">{{ article.published_at | date: '%d.%m.%Y' }}{% if article.author != blank %} &middot; {{ article.author }}{% endif %}</p>

      {% if article.image %}
        <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title }}" style="border-radius: 1rem; margin: 2rem 0;" width="1200" height="{{ 1200 | divided_by: article.image.aspect_ratio | default: 1200 }}">
      {% endif %}

      <div class="rich-text__content">
        {{ article.content }}
      </div>
    </div>

    {% if blog.comments_enabled? %}
      <div class="rich-text" style="margin-top: 3rem; border-top: 1px solid rgba(11,11,12,0.1); padding-top: 2rem;">
        <h2>{{ 'blogs.comments.title' | t }} ({{ article.comments_count }})</h2>
        {% for comment in article.comments %}
          <div style="margin-bottom: 1.5rem;">
            <strong>{{ comment.author }}</strong>
            <p>{{ comment.content }}</p>
          </div>
        {% endfor %}

        {% form 'new_comment', article %}
          {% if form.posted_successfully? %}
            <div class="form-message form-message--success">Danke für deinen Kommentar!</div>
          {% endif %}
          <div class="form-grid form-grid--split">
            <div class="form-field">
              <label for="CommentAuthor">{{ 'blogs.comments.name' | t }}</label>
              <input type="text" id="CommentAuthor" name="comment[author]" required>
            </div>
            <div class="form-field">
              <label for="CommentEmail">{{ 'blogs.comments.email' | t }}</label>
              <input type="email" id="CommentEmail" name="comment[email]" required>
            </div>
          </div>
          <div class="form-field" style="margin-top:1.25rem;">
            <label for="CommentBody">{{ 'blogs.comments.message' | t }}</label>
            <textarea id="CommentBody" name="comment[body]" rows="4" required></textarea>
          </div>
          <button type="submit" class="button button--dark" style="margin-top:1.25rem;">{{ 'blogs.comments.post' | t }}</button>
        {% endform %}
      </div>
    {% endif %}
  </div>
</article>

{% schema %}
{ "name": "Artikel", "settings": [] }
{% endschema %}
