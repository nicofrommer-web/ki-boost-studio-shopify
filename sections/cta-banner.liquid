<div class="section-padding--tight">
  <div class="container">
    <div class="cta-banner">
      {% if section.settings.heading != blank %}
        <h2 class="cta-banner__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p class="cta-banner__text">{{ section.settings.text }}</p>
      {% endif %}
      <div class="cta-banner__actions">
        {% if section.settings.primary_label != blank %}
          <a href="{{ section.settings.primary_url }}" class="button button--primary">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a href="{{ section.settings.secondary_url }}" class="button button--outline">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CTA-Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Bereit für mehr Effizienz und mehr Umsatz?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Vereinbare jetzt dein kostenloses Erstgespräch und erfahre, wie KI Boost Studio dein Unternehmen voranbringt." },
    { "type": "text", "id": "primary_label", "label": "Primärer Button Text", "default": "Kostenloses Erstgespräch sichern" },
    { "type": "url", "id": "primary_url", "label": "Primärer Button Link" },
    { "type": "text", "id": "secondary_label", "label": "Sekundärer Button Text", "default": "" },
    { "type": "url", "id": "secondary_url", "label": "Sekundärer Button Link" }
  ],
  "presets": [{ "name": "CTA-Banner" }]
}
{% endschema %}
