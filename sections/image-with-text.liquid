<section class="section-padding {{ section.settings.background }}">
  <div class="container">
    <div class="image-with-text {% if section.settings.reverse %}image-with-text--reverse{% endif %}">
      <div class="image-with-text__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            loading="lazy"
            width="900"
            height="{{ 900 | divided_by: section.settings.image.aspect_ratio }}"
          >
        {% else %}
          <div style="aspect-ratio: 4/3; background: var(--color-offwhite); border-radius: 1.25rem;"></div>
        {% endif %}
      </div>

      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="heading-xl">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="rich-text">{{ section.settings.text }}</div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <ul class="image-with-text__list">
            {% for block in section.blocks %}
              {% if block.type == 'bullet' %}
                <li {{ block.shopify_attributes }}>{% render 'icon-check' %} <span>{{ block.settings.text }}</span></li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}

        {% if section.settings.cta_label != blank %}
          <div style="margin-top: 2rem;">
            <a href="{{ section.settings.cta_url }}" class="button button--dark">{{ section.settings.cta_label }}</a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bild mit Text",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "bg-white", "label": "Weiß" },
        { "value": "bg-offwhite", "label": "Off-White" }
      ],
      "default": "bg-white"
    },
    { "type": "checkbox", "id": "reverse", "label": "Bild rechts anzeigen", "default": false },
    { "type": "image_picker", "id": "image", "label": "Bild" },
    { "type": "text", "id": "eyebrow", "label": "Kicker-Text" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Überschrift" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Beschreibungstext hier eingeben.</p>" },
    { "type": "text", "id": "cta_label", "label": "Button-Text", "default": "Jetzt anfragen" },
    { "type": "url", "id": "cta_url", "label": "Button-Link" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Stichpunkt",
      "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Stichpunkt" }]
    }
  ],
  "presets": [{ "name": "Bild mit Text" }]
}
{% endschema %}
