<div class="section-padding">
  <div class="container">
    <h1 class="heading-xl" style="margin-bottom: 2rem;">{{ 'cart.general.title' | t }}</h1>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <table class="cart-table">
          <thead>
            <tr>
              <th></th>
              <th>Produkt</th>
              <th>{{ 'cart.general.quantity' | t }}</th>
              <th>{{ 'cart.general.subtotal' | t }}</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  {% if item.image %}
                    <img class="cart-line__media" src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" loading="lazy">
                  {% endif %}
                </td>
                <td>
                  <a href="{{ item.url }}" style="font-weight:700;">{{ item.product.title }}</a>
                  {% if item.variant.title != 'Default Title' %}
                    <div style="opacity:0.6; font-size:0.85rem;">{{ item.variant.title }}</div>
                  {% endif %}
                </td>
                <td>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width: 4.5rem; padding: 0.5em; border-radius: 0.5rem; border: 1.5px solid rgba(11,11,12,0.15);">
                </td>
                <td>{{ item.final_line_price | money }}</td>
                <td><a href="{{ item.url_to_remove }}">{{ 'cart.general.remove' | t }}</a></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="cart-summary">
          <p class="cart-summary__total">{{ 'cart.general.subtotal' | t }}: {{ cart.total_price | money }}</p>
          <button type="submit" name="update" class="button button--outline">{{ 'cart.general.update' | t }}</button>
          <button type="submit" name="checkout" class="button button--primary">{{ 'cart.general.checkout' | t }}</button>
        </div>
      </form>
    {% else %}
      <div class="empty-state">
        <p>{{ 'cart.general.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button--dark">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{ "name": "Warenkorb", "settings": [] }
{% endschema %}
