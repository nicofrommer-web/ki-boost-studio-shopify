<div class="section-padding">
  <div class="container">
    <div class="section-heading">
      <h1 class="heading-xl">{{ 'general.search.title' | t }}</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" class="form-field" style="max-width: 28rem; flex-direction: row; gap: 0.75rem;">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" style="flex-grow:1;">
        <input type="hidden" name="type" value="product,article,page">
        <button type="submit" class="button button--dark">{{ 'general.search.search' | t }}</button>
      </form>
    </div>

    {% if search.performed %}
      {% if search.results.size > 0 %}
        <p style="opacity:0.7; margin-bottom: 2rem;">
          {% if search.results.size == 1 %}
            {{ 'general.search.results_with_count.one' | t: count: search.results_count }}
          {% else %}
            {{ 'general.search.results_with_count.other' | t: count: search.results_count }}
          {% endif %}
        </p>
        <div class="collection-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% render 'product-card', product: item %}
            {% else %}
              <a href="{{ item.url }}" class="product-card">
                <p class="product-card__title">{{ item.title }}</p>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <p class="empty-state">{{ 'general.search.no_results_html' | t: terms: search.terms }}</p>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{ "name": "Suche", "settings": [] }
{% endschema %}
