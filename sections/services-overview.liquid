<section class="section-padding {{ section.settings.background }}">
  <div class="container">
    <div class="section-heading {% if section.settings.center_heading %}text-center{% endif %}">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="heading-xl">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="section-heading__lede">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="grid grid--4">
      {% for block in section.blocks %}
        {% if block.type == 'service' %}
          <div class="service-card" {{ block.shopify_attributes }}>
            <div class="service-card__icon">
              {% render 'icon-render', icon: block.settings.icon %}
            </div>
            <h3 class="service-card__title">{{ block.settings.title }}</h3>
            <p class="service-card__text">{{ block.settings.text }}</p>
            {% if block.settings.url != blank %}
              <a href="{{ block.settings.url }}" class="service-card__link">
                {{ block.settings.link_label | default: 'Mehr erfahren' }} {% render 'icon-arrow-right' %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Leistungsübersicht",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "bg-white", "label": "Weiß" },
        { "value": "bg-offwhite", "label": "Off-White" }
      ],
      "default": "bg-white"
    },
    {
      "type": "checkbox",
      "id": "center_heading",
      "label": "Überschrift zentrieren",
      "default": true
    },
    { "type": "text", "id": "eyebrow", "label": "Kicker-Text", "default": "Unsere Leistungen" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Alles, was dein Business nach vorne bringt" },
    { "type": "textarea", "id": "subheading", "label": "Untertitel", "default": "Vier Kernleistungen, die sich perfekt ergänzen – einzeln buchbar oder als starkes Gesamtpaket." }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Leistung",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "automation", "label": "Automation" },
            { "value": "leads", "label": "Leads" },
            { "value": "social", "label": "Social Media" },
            { "value": "web", "label": "Webseite" },
            { "value": "chart", "label": "Wachstum" },
            { "value": "shield", "label": "Sicherheit" }
          ],
          "default": "automation"
        },
        { "type": "text", "id": "title", "label": "Titel", "default": "KI-Automationen" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Wir automatisieren wiederkehrende Aufgaben mit KI – von der Kundenkommunikation bis zur internen Prozessteuerung." },
        { "type": "text", "id": "link_label", "label": "Link-Text", "default": "Mehr erfahren" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leistungsübersicht",
      "blocks": [
        { "type": "service", "settings": { "icon": "automation", "title": "KI-Automationen", "text": "Wir automatisieren wiederkehrende Aufgaben mit KI – von der Kundenkommunikation bis zur internen Prozessteuerung.", "url": "/pages/ki-automationen" } },
        { "type": "service", "settings": { "icon": "leads", "title": "Leadgenerierung", "text": "Planbar neue Anfragen gewinnen statt auf Zufall zu hoffen – mit System, Funnel und klarer Strategie.", "url": "/pages/leadgenerierung" } },
        { "type": "service", "settings": { "icon": "social", "title": "Social-Media-Content", "text": "Hochwertiger Content, der deine Marke sichtbar macht und deine Zielgruppe wirklich erreicht.", "url": "/pages/social-media-content" } },
        { "type": "service", "settings": { "icon": "web", "title": "Webseiten-Erstellung", "text": "Moderne, schnelle und conversion-starke Webseiten, die aus Besuchern Kunden machen.", "url": "/pages/webseiten-erstellung" } }
      ]
    }
  ]
}
{% endschema %}
