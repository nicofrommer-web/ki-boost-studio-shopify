<section class="section-padding {{ section.settings.background }}">
  <div class="container">
    <div class="section-heading {% if section.settings.center_heading %}text-center{% endif %}">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="heading-xl">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="section-heading__lede">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="process-steps">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="process-step" {{ block.shopify_attributes }}>
            <span class="process-step__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <h3 class="process-step__title">{{ block.settings.title }}</h3>
            <p class="process-step__text">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ablauf in 3 Schritten",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Hintergrund",
      "options": [
        { "value": "bg-white", "label": "Weiß" },
        { "value": "bg-offwhite", "label": "Off-White" }
      ],
      "default": "bg-white"
    },
    { "type": "checkbox", "id": "center_heading", "label": "Überschrift zentrieren", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Kicker-Text", "default": "So läuft es ab" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "In 3 Schritten zu mehr Erfolg" },
    { "type": "textarea", "id": "subheading", "label": "Untertitel", "default": "Unser bewährter Prozess sorgt für einen reibungslosen Start – ohne Aufwand für dich." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Schritt",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Kostenloses Erstgespräch" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Wir lernen dein Unternehmen kennen und analysieren deine Ausgangssituation und Ziele." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ablauf in 3 Schritten",
      "blocks": [
        { "type": "step", "settings": { "title": "Kostenloses Erstgespräch", "text": "Wir lernen dein Unternehmen kennen und analysieren deine Ausgangssituation und Ziele." } },
        { "type": "step", "settings": { "title": "Individuelles Konzept", "text": "Du erhältst eine maßgeschneiderte Strategie inklusive transparentem Angebot." } },
        { "type": "step", "settings": { "title": "Umsetzung & Betreuung", "text": "Wir setzen alles um und begleiten dich danach laufend mit Optimierungen." } }
      ]
    }
  ]
}
{% endschema %}
