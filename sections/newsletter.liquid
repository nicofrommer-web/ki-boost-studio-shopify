{% if section.settings.enable %}
<section class="section-padding--tight bg-black newsletter">
  <div class="container newsletter__inner">
    <div>
      <h2 class="heading-lg" style="margin-bottom: 0.35rem;">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p style="opacity:0.7; margin:0;">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    {% form 'customer', id: 'NewsletterForm' %}
      {% if form.posted_successfully? %}
        <p style="color: var(--color-gold); font-weight: 700;">{{ 'general.newsletter_form.confirmation' | t }}</p>
      {% else %}
        <div class="newsletter__form">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="NewsletterEmail" class="visually-hidden">{{ 'general.newsletter_form.newsletter_email' | t }}</label>
          <input
            type="email"
            id="NewsletterEmail"
            name="contact[email]"
            placeholder="{{ 'general.newsletter_form.placeholder' | t }}"
            autocomplete="email"
            required
          >
          <button type="submit" class="button button--primary">{{ 'general.newsletter_form.submit' | t }}</button>
        </div>
      {% endif %}
    {% endform %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "checkbox", "id": "enable", "label": "Newsletter-Bereich anzeigen", "default": true },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Bleib auf dem Laufenden" },
    { "type": "text", "id": "text", "label": "Text", "default": "KI-Trends, Tipps und Neuigkeiten von KI Boost Studio – direkt in dein Postfach." }
  ]
}
{% endschema %}
