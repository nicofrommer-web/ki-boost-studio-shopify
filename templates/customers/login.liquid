<div class="section-padding">
  <div class="container narrow-form">
    <h1 class="heading-xl">{{ 'customer.login_page.sign_in' | t }}</h1>

    {% form 'customer_login' %}
      {% if form.errors %}
        <div class="form-message form-message--error">{{ form.errors.messages['form'] }}</div>
      {% endif %}

      <div class="form-field" style="margin-bottom: 1.25rem;">
        <label for="CustomerEmail">{{ 'customer.login_page.email' | t }}</label>
        <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" required>
      </div>

      {% if form.password_needed %}
        <div class="form-field" style="margin-bottom: 1.25rem;">
          <label for="CustomerPassword">{{ 'customer.login_page.password' | t }}</label>
          <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" required>
        </div>
        <p style="margin-bottom:1.25rem;"><a href="{{ routes.account_recover_url }}">{{ 'customer.login_page.forgot_password' | t }}</a></p>
      {% endif %}

      <button type="submit" class="button button--dark button--block">{{ 'customer.login_page.sign_in_submit' | t }}</button>
    {% endform %}

    <p style="margin-top: 1.5rem;">
      {{ 'customer.login_page.create_account' | t }}? <a href="{{ routes.account_register_url }}">{{ 'customer.register.submit' | t }}</a>
    </p>
  </div>
</div>
