<div class="section-padding">
  <div class="container">
    <h1 class="heading-xl">{{ 'customer.account.title' | t }}</h1>

    <div class="account-nav">
      <a href="{{ routes.account_url }}" style="font-weight:700;">{{ 'customer.account.details' | t }}</a>
      <a href="{{ routes.account_addresses_url }}">{{ 'customer.account.view_addresses' | t }}</a>
      <a href="{{ routes.account_logout_url }}">{{ 'customer.log_out' | t }}</a>
    </div>

    <h2 style="font-size:1.2rem;">{{ 'customer.orders.title' | t }}</h2>
    {% if customer.orders.size > 0 %}
      <table class="account-table">
        <thead>
          <tr>
            <th>{{ 'customer.orders.order_number' | t }}</th>
            <th>{{ 'customer.orders.date' | t }}</th>
            <th>{{ 'customer.orders.payment_status' | t }}</th>
            <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
            <th>{{ 'customer.orders.total' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {% for order in customer.orders %}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%d.%m.%Y' }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p style="opacity:0.7;">{{ 'customer.orders.none' | t }}</p>
    {% endif %}
  </div>
</div>
