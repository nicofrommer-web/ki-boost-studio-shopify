<div class="section-padding">
  <div class="container narrow-form">
    <h1 class="heading-xl">{{ 'customer.register.title' | t }}</h1>

    {% form 'create_customer' %}
      {% if form.errors %}
        <div class="form-message form-message--error">
          <ul style="margin:0;">
            {% for field in form.errors %}
              <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      <div class="form-grid form-grid--split" style="margin-bottom: 1.25rem;">
        <div class="form-field">
          <label for="RegisterFirstName">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" id="RegisterFirstName" name="customer[first_name]" autocomplete="given-name">
        </div>
        <div class="form-field">
          <label for="RegisterLastName">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" id="RegisterLastName" name="customer[last_name]" autocomplete="family-name">
        </div>
      </div>

      <div class="form-field" style="margin-bottom: 1.25rem;">
        <label for="RegisterEmail">{{ 'customer.register.email' | t }}</label>
        <input type="email" id="RegisterEmail" name="customer[email]" autocomplete="email" required>
      </div>

      <div class="form-field" style="margin-bottom: 1.25rem;">
        <label for="RegisterPassword">{{ 'customer.register.password' | t }}</label>
        <input type="password" id="RegisterPassword" name="customer[password]" autocomplete="new-password" required>
      </div>

      <button type="submit" class="button button--dark button--block">{{ 'customer.register.submit' | t }}</button>
    {% endform %}
  </div>
</div>
