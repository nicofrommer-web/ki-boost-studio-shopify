<div class="section-padding">
  <div class="container">
    <p><a href="{{ routes.account_url }}">&larr; {{ 'customer.account.return' | t }}</a></p>
    <h1 class="heading-xl">{{ 'customer.order.title' | t: name: order.name }}</h1>
    <p style="opacity:0.7;">{{ 'customer.order.date_html' | t: date: order.created_at | date: '%d.%m.%Y' }}</p>

    <table class="account-table" style="margin-top: 2rem;">
      <thead>
        <tr>
          <th>{{ 'customer.order.product' | t }}</th>
          <th>{{ 'customer.order.price' | t }}</th>
          <th>{{ 'customer.order.quantity' | t }}</th>
          <th>{{ 'customer.order.total' | t }}</th>
        </tr>
      </thead>
      <tbody>
        {% for line_item in order.line_items %}
          <tr>
            <td>{{ line_item.title }}</td>
            <td>{{ line_item.price | money }}</td>
            <td>{{ line_item.quantity }}</td>
            <td>{{ line_item.final_line_price | money }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <div class="cart-summary">
      <p class="cart-summary__total">{{ 'customer.order.total' | t }}: {{ order.total_price | money }}</p>
    </div>

    <div class="grid grid--2" style="margin-top: 2rem;">
      <div>
        <h2 style="font-size:1.05rem;">{{ 'customer.order.billing_address' | t }}</h2>
        <p>{{ order.billing_address | format_address }}</p>
      </div>
      <div>
        <h2 style="font-size:1.05rem;">{{ 'customer.order.shipping_address' | t }}</h2>
        <p>{{ order.shipping_address | format_address }}</p>
      </div>
    </div>
  </div>
</div>
